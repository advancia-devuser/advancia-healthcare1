{
  "name": "advancia-smart-wallets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:standalone": "next build --webpack && node scripts/prepare-standalone.js",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint .",
    "check:docs-sync": "node scripts/validate-doc-sync.js",
    "hash:admin": "node scripts/generate-admin-password-hash.js",
    "trigger:post-deploy:dispatch": "bash scripts/trigger-post-deploy-verify.sh",
    "trigger:post-deploy:dispatch:ps": "pwsh -File scripts/trigger-post-deploy-verify.ps1",
    "check:gh-actions:ps": "pwsh -File scripts/check-github-actions-readiness.ps1",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:e2e": "jest --config jest.config.cjs --runInBand --testPathPattern=e2e",
    "postinstall": "prisma generate && node scripts/postinstall.js",
    "prepare": "node scripts/prepare-husky.js",
    "dev:cli": "node scripts/dev-cli.js",
    "dev:health": "node scripts/dev-cli.js health",
    "dev:db": "node scripts/dev-cli.js db",
    "dev:reset": "node scripts/dev-cli.js reset",
    "dev:secrets": "node scripts/dev-cli.js secrets",
    "deploy:check": "node scripts/dev-cli.js deploy",
    "db:reset": "npx prisma migrate reset --force",
    "db:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "docker:up": "docker compose -f docker-compose.postgres.yml up -d",
    "docker:down": "docker compose -f docker-compose.postgres.yml down"
  },
  "dependencies": {
    "@account-kit/core": "^4.86.0",
    "@account-kit/infra": "^4.86.0",
    "@account-kit/react": "^4.86.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.50.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "lucide-react": "^0.511.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.47.2",
    "wagmi": "^2.15.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.17.2",
    "pino-pretty": "^13.1.1",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "react-test-renderer": "^19.2.4",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.2.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@base-org/account": "2.5.2",
    "hono": "4.12.7",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "10.2.4"
    },
    "@eslint/config-array": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.5"
    },
    "glob": {
      "minimatch": "3.1.5"
    },
    "@walletconnect/core": "2.23.8",
    "@walletconnect/sign-client": "2.23.8",
    "@walletconnect/types": "2.23.8",
    "@walletconnect/universal-provider": "2.23.8",
    "@walletconnect/utils": "2.23.8",
    "lodash": "4.17.23",
    "test-exclude": {
      "minimatch": "3.1.5"
    },
    "@tanstack/form-core": "^0.42.1",
    "@tanstack/react-form": "^0.42.1",
    "@tanstack/zod-form-adapter": "^0.42.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
