# Retrieve your API Key and Policy ID from the smart wallets dashboard default configuration or create new keys: https://dashboard.alchemy.com/services/smart-wallets/configuration
NEXT_PUBLIC_ALCHEMY_API_KEY=YOUR_APP_API_KEY # Get your app API key: https://dashboard.alchemy.com/apps
NEXT_PUBLIC_ALCHEMY_POLICY_ID=YOUR_SPONSORSHIP_POLICY_ID # Get your gas sponsorship policy ID: https://dashboard.alchemy.com/services/gas-manager/configuration
NEXT_PUBLIC_CHAIN_ID=421614 # Arbitrum Sepolia as default
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Public site URL for emails, sitemap, and robots metadata
PAYROLL_REDIRECT_TARGET="" # Optional: set to https://advanciapayledger.com only if payroll-domain traffic should redirect there
# NOTE: make sure to set up a smart wallet configuration for your app to enable login

# --- Server-side (Next.js route handlers) ---
# Prisma is configured for Postgres. Use either Supabase or Neon.
# If this repository is deployed separately, keep it on its own database project.
# Do not reuse the canonical modullar-advancia production Supabase project here.
# Supabase example:
# DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
# Supabase pooler example for Node pg compatibility:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require&pgbouncer=true&connection_limit=1"
# Neon example:
# DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# If this app uses Supabase Auth or client-side Supabase features, keep those keys scoped
# to this repository's dedicated Supabase project as well.
# Use the project's public browser key here. Supabase may label it as an anon key
# or a publishable key depending on dashboard/version.
SUPABASE_URL="https://your-dedicated-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-dedicated-supabase-anon-key"

# Admin console password used to mint an httpOnly admin session cookie.
# DEV ONLY fallback (not allowed in production):
ADMIN_PASSWORD="admin2026"

# Preferred admin password secret (bcrypt hash). REQUIRED in production.
# Generate with: node -e "require('bcryptjs').hash('your-strong-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$replace.with.your.bcrypt.hash................................"

# Secret used to sign admin session JWTs (min 32 chars recommended)
ADMIN_JWT_SECRET="change-me-change-me-change-me-change-me"

# Secret used to sign user session JWTs (min 32 chars recommended)
USER_JWT_SECRET="change-me-change-me-change-me-change-me"

# Optional Redis REST backend for persistent nonce/rate-limits/lockouts
# (recommended for multi-instance deployments)
REDIS_REST_URL="https://<your-redis-endpoint>.upstash.io"
REDIS_REST_TOKEN="your-redis-rest-token"

# ──────────────────────────────────────────────────────────────────────────────
# 📧 EMAIL & SMS (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────────
# Used for sending OTPs, withdrawal confirmations, and health reminders.
# Example: Resend, SendGrid, Twilio
RESEND_API_KEY="re_your_resend_api_key"
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Textbelt (simple SMS API). Use TEXTBELT_API_KEY (preferred) or TEXTBELT (alias).
TEXTBELT_API_KEY="textbelt_or_paid_key"
# TEXTBELT="textbelt_or_paid_key"

# ──────────────────────────────────────────────────────────────────────────────
# 💳 FIAT ON-RAMP PROVIDERS (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────────
# Used for the "Buy Crypto" widget (Transak, MoonPay, Ramp)
NEXT_PUBLIC_TRANSAK_API_KEY="your-transak-api-key"
NEXT_PUBLIC_MOONPAY_API_KEY="your-moonpay-api-key"
NEXT_PUBLIC_RAMP_API_KEY="your-ramp-api-key"

# ──────────────────────────────────────────────────────────────────────────────
# 🏥 HEALTH MODULE ENCRYPTION
# ──────────────────────────────────────────────────────────────────────────────
# Used to encrypt sensitive health card data (Insurance, Prescriptions) before
# saving to the database. Must be exactly 32 bytes (256 bits) hex encoded.
# Example: `openssl rand -hex 32`
# Preferred name:
HEALTH_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# Backward-compatible alias:
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# ──────────────────────────────────────────────────────────────────────────────
# 🔒 CRON JOB AUTH (RECOMMENDED)
# ──────────────────────────────────────────────────────────────────────────────
# Secures /api/cron/* endpoints. Vercel auto-injects this for cron jobs.
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me-to-a-random-secret"

# ──────────────────────────────────────────────────────────────────────────────
# � ALCHEMY WEBHOOKS
# ──────────────────────────────────────────────────────────────────────────────
# Token used to verify incoming Alchemy Address Activity webhooks.
# Set this to match the Auth Token configured in the Alchemy Notify dashboard.
ALCHEMY_WEBHOOK_SECRET="your-alchemy-webhook-auth-token"

# ──────────────────────────────────────────────────────────────────────────────
# 💰 HOT WALLET (OPTIONAL — on-chain withdrawals)
# ──────────────────────────────────────────────────────────────────────────────
# Private key (0x-prefixed hex) of the funded hot wallet that signs withdrawal
# transactions. Without this, the withdrawal cron simulates broadcasts.
# ⚠️  NEVER commit a real private key — use GitHub Secrets or Vercel env vars.
# HOT_WALLET_PRIVATE_KEY="0x..."

# ──────────────────────────────────────────────────────────────────────────────
# �📋 LOGGING
# ──────────────────────────────────────────────────────────────────────────────
# Controls the minimum log level for lib/logger.ts
# Valid values: debug, info, warn, error, fatal (default: info)
LOG_LEVEL="info"